# ─── Veritabanı ───────────────────────────────────────────────
# Yerel: file:./prisma/dev.db
# Production (Turso): libsql://your-db.turso.io
DATABASE_URL="file:./prisma/dev.db"
TURSO_AUTH_TOKEN=""

# ─── NextAuth ─────────────────────────────────────────────────
AUTH_SECRET="openssl rand -base64 32 ile üretin"
# AUTH_URL: sadece domain (path yok). Örnek: https://guchat.org
# basePath /api/auth, kod içinde sabitlenmiştir (lib/auth.ts).
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ─── Uygulama URL'leri ────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: ayrı Socket.io sunucusu (Railway/Fly.io)
NEXT_PUBLIC_SOCKET_URL=""
# Marketing sayfası widget embed (guchat.org sitesinin WEBSITE_ID'si)
NEXT_PUBLIC_MARKETING_WEBSITE_ID=""
# guchat.org ana sayfasında kendi canlı sohbet widget'ınızı göstermek için
# panelden (Widget Ayarları) aldığınız Website ID'sini girin. Boşsa widget gösterilmez.
NEXT_PUBLIC_WIDGET_WEBSITE_ID=""

# ─── Google OAuth (opsiyonel) ─────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Dosya Yükleme — S3 (opsiyonel, yoksa public/uploads) ───
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-central-1"
AWS_S3_BUCKET=""
AWS_S3_PUBLIC_URL=""

# ─── E-posta — SMTP (opsiyonel) ───────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@guchat.org"

# ─── PayTR Ödeme (opsiyonel) ──────────────────────────────────
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
PAYTR_TEST_MODE="1"
NEXT_PUBLIC_PAYTR_ENABLED="false"

# ─── AI Sohbet Asistanı (en az biri önerilir) ─────────────────
# Platform anahtarları tüm müşterilere sunulur; site başına özel anahtar da girilebilir.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
GOOGLE_AI_API_KEY=""
GROQ_API_KEY=""
# Ücretsiz açık kaynak modeller (Llama, Gemma, Qwen): https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Kendi Ollama sunucunuz (Railway/VPS): https://github.com/ollama/ollama
OLLAMA_BASE_URL=""
OLLAMA_API_KEY="ollama"
# Otomatik çeviri için (lib/ai/translate.ts ve app/api/translate/route.ts)
GOOGLE_TRANSLATE_API_KEY=""

# ─── Cron Güvenlik ────────────────────────────────────────────
# Vercel Cron Job'larını korumak için rastgele bir string girin.
# openssl rand -base64 32 ile üretin.
# ZORUNLU: Boş bırakılırsa cron endpoint'leri herkese açık olur!
CRON_SECRET=""

# ─── Socket Sunucusu (Railway) ────────────────────────────────
# SOCKET_PORT=3001
# NEXT_PUBLIC_APP_URL=https://guchat.org (CORS için)

# ─── Platform Admin ───────────────────────────────────────────
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
WHATSAPP_APP_SECRET=""
