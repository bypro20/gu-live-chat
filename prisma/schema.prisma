generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── ACCOUNT & AUTH ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  role          UserRole  @default(USER)
  activeWebsiteId String?   // Currently selected website context
  lastSeenAt    DateTime?

  memberships        TeamMember[]
  ownedWebsites      Website[]  @relation("WebsiteOwner")
  assignedTo         ConversationAssignment[]
  assignedConversations Conversation[] @relation("ConversationAssignee")
  notes              Note[]
  sentMessages       Message[]  @relation("MessageSender")
  notifications      Notification[]

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── MULTI-TENANCY ─────────────────────────────────────────────

model Website {
  id        String   @id @default(cuid())
  name      String
  domain    String
  websiteId String   @unique
  plan      Plan     @default(FREE)

  // Widget Customization
  primaryColor   String         @default("#0074E0")
  position      WidgetPosition @default(BOTTOM_RIGHT)
  avatarUrl     String?
  welcomeMessage String        @default("Merhaba! Size nasıl yardımcı olabiliriz?")
  offlineMessage String        @default("Şu an çevrimdışısınız. Bir mesaj bırakın, size dönelim.")

  // Relations
  ownerId         String
  owner           User           @relation("WebsiteOwner", fields: [ownerId], references: [id])
  members         TeamMember[]
  conversations   Conversation[]
  visitors        Visitor[]
  cannedResponses CannedResponse[]
  chatbots        Chatbot[]
  webhooks        Webhook[]
  tags            Tag[]
  visitorSessions VisitorSession[]
  aiConfig        AIConfig?
  invoices        Invoice[]
  analytics       AnalyticsSnapshot[]
  notifications   Notification[]

  // PayTR
  paytrMerchantOid      String?            @unique
  paytrUserToken        String?            // utoken — stored card reference
  paytrCardToken        String?            // ctoken — stored card identifier
  subscriptionStatus    SubscriptionStatus @default(NONE)
  currentPeriodEnd      DateTime?
  failedPayments        Int                @default(0)

  // Trial
  trialStartsAt         DateTime?
  trialEndsAt           DateTime?
  trialUsed             Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("websites")
}

model TeamMember {
  id        String   @id @default(cuid())
  role      TeamRole @default(MEMBER)
  userId    String
  websiteId String
  invitedBy  String?
  invitedAt  DateTime?
  acceptedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([userId, websiteId])
  @@map("team_members")
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum WidgetPosition {
  BOTTOM_RIGHT
  BOTTOM_LEFT
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  NEW_CONVERSATION
  NEW_MESSAGE
  CONVERSATION_ASSIGNED
  CONVERSATION_RESOLVED
  TEAM_MEMBER_JOINED
  TEAM_MEMBER_REMOVED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  PAYMENT_FAILED
  PAYMENT_SUCCESS
  LIMIT_WARNING
  TRIAL_EXPIRING
}

enum AnalyticsType {
  DAILY
  WEEKLY
  MONTHLY
}

// ─── VISITORS & SESSIONS ──────────────────────────────────────

model Visitor {
  id          String   @id @default(cuid())
  websiteId   String
  fingerprint String
  email       String?
  name        String?
  phone       String?
  avatarUrl   String?
  notes       String?
  customData  String?

  // CRM enrichment
  country  String?
  city     String?
  timezone String?
  browser  String?
  os       String?
  device   String?

  // Relations
  website      Website         @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  sessions     VisitorSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([websiteId, fingerprint])
  @@map("visitors")
}

model VisitorSession {
  id          String   @id @default(cuid())
  visitorId   String
  websiteId   String

  sessionId   String   @unique
  landingPage String?
  currentPage String?
  currentTitle String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  ipAddress   String?
  userAgent   String?
  country     String?
  city        String?

  pages       PageView[]

  visitor     Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  startedAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  endedAt      DateTime?

  @@index([websiteId, endedAt])
  @@index([websiteId, lastActiveAt])
  @@map("visitor_sessions")
}

model PageView {
  id        String   @id @default(cuid())
  sessionId String
  url       String
  title     String?
  duration  Int?

  session   VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  viewedAt  DateTime @default(now())

  @@map("page_views")
}

// ─── CONVERSATIONS & MESSAGES ─────────────────────────────────

model Conversation {
  id          String   @id @default(cuid())
  websiteId   String
  visitorId   String

  status      ConversationStatus @default(OPEN)
  source      ConversationSource  @default(WIDGET)
  subject     String?

  // Assignment
  assignedToId String?
  assignedTo   User?  @relation("ConversationAssignee", fields: [assignedToId], references: [id])
  assignments  ConversationAssignment[]

  // Relations
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  visitor     Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  messages    Message[]
  tags        ConversationTag[]
  notes       Note[]

  // Metadata
  lastMessageAt     DateTime @default(now())
  lastMessagePreview String?
  unreadCount       Int      @default(0)

  // Chatbot
  chatbotId    String?
  chatbot      Chatbot?  @relation(fields: [chatbotId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([websiteId, status])
  @@index([websiteId, lastMessageAt])
  @@index([websiteId, createdAt])
  @@map("conversations")
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum ConversationSource {
  WIDGET
  API
  IMPORT
}

model ConversationAssignment {
  id             String   @id @default(cuid())
  conversationId String
  userId         String

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignedBy     String?
  assignedAt     DateTime @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_assignments")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  content        String
  type           MessageType @default(TEXT)
  senderType     SenderType

  // For agent messages
  senderId       String?
  sender         User?    @relation("MessageSender", fields: [senderId], references: [id])

  // Status
  status         MessageStatus @default(SENT)
  readAt         DateTime?
  deliveredAt    DateTime?

  // Attachments
  attachments    Attachment[]

  // Metadata
  metadata       String?
  editedAt       DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
  BOT
}

enum SenderType {
  VISITOR
  AGENT
  BOT
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model Attachment {
  id           String   @id @default(cuid())
  messageId    String
  url          String
  fileName     String
  fileSize     Int?
  mimeType     String?
  thumbnailUrl String?

  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@map("attachments")
}

// ─── TAGS & NOTES ─────────────────────────────────────────────

model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#6B7280")
  websiteId   String

  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  conversations ConversationTag[]

  @@unique([websiteId, name])
  @@map("tags")
}

model ConversationTag {
  conversationId String
  tagId          String

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([conversationId, tagId])
  @@map("conversation_tags")
}

model Note {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  content        String

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("notes")
}

// ─── CANNED RESPONSES ──────────────────────────────────────────

model CannedResponse {
  id          String   @id @default(cuid())
  websiteId   String
  title       String
  content     String
  shortcut    String?
  category    String?

  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([websiteId, shortcut])
  @@map("canned_responses")
}

// ─── CHATBOT / AUTO-RESPONDER ─────────────────────────────────

model Chatbot {
  id          String   @id @default(cuid())
  websiteId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  trigger     ChatbotTrigger @default(ALL_CONVERSATIONS)

  steps       ChatbotStep[]
  conversations Conversation[]

  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("chatbots")
}

enum ChatbotTrigger {
  ALL_CONVERSATIONS
  OFFLINE_ONLY
  KEYWORD
  FIRST_VISIT
}

model ChatbotStep {
  id          String   @id @default(cuid())
  chatbotId   String
  order       Int

  // Step config
  type        ChatbotStepType
  message     String?
  options     String?
  nextStepId  String?

  chatbot     Chatbot   @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@map("chatbot_steps")
}

enum ChatbotStepType {
  MESSAGE
  CHOICE
  COLLECT_EMAIL
  COLLECT_NAME
  ASSIGN_AGENT
  END
}

// ─── WEBHOOKS ──────────────────────────────────────────────────

model Webhook {
  id          String   @id @default(cuid())
  websiteId   String
  url         String
  secret      String
  isActive    Boolean  @default(true)

  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  events      WebhookEvent[]

  lastTriggeredAt DateTime?
  failureCount    Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("webhooks")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  webhookId String
  event     String

  webhook   Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_events")
}

// ─── AUDIT LOG ────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  websiteId   String
  userId      String?
  action      String
  entity      String
  entityId    String?
  details     String?

  createdAt   DateTime @default(now())

  @@index([websiteId, action])
  @@map("audit_logs")
}

// ─── AI CONFIG ──────────────────────────────────────────────────

model AIConfig {
  id            String   @id @default(cuid())
  websiteId     String   @unique
  isActive      Boolean  @default(false)
  provider      AIProvider @default(OPENAI)
  model         String   @default("gpt-4o-mini")
  apiKey        String   // Stored encrypted in production
  temperature   Float    @default(0.7)
  systemPrompt  String?
  autoSuggest   Boolean  @default(true)
  autoReply     Boolean  @default(false)

  website       Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("ai_configs")
}

enum AIProvider {
  OPENAI
  ANTHROPIC
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String
  websiteId  String
  type       NotificationType
  title      String
  message    String
  data       String?          // JSON string for additional context
  readAt     DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── INVOICES ───────────────────────────────────────────────────

model Invoice {
  id              String       @id @default(cuid())
  websiteId      String
  plan            Plan
  amount          Int          // In kuruş (cents)
  currency        String       @default("TRY")
  status          InvoiceStatus @default(PENDING)
  periodStart     DateTime
  periodEnd       DateTime
  paytrMerchantOid String?
  pdfUrl          String?

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([websiteId, createdAt])
  @@map("invoices")
}

// ─── ANALYTICS SNAPSHOTS ────────────────────────────────────────

model AnalyticsSnapshot {
  id                    String        @id @default(cuid())
  websiteId            String
  date                  DateTime
  type                  AnalyticsType

  conversationsCreated  Int           @default(0)
  conversationsResolved Int           @default(0)
  uniqueVisitors        Int           @default(0)
  messagesSent          Int           @default(0)
  avgFirstResponseMs    Int           @default(0)
  avgResolutionMs       Int           @default(0)

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([websiteId, date, type])
  @@map("analytics_snapshots")
}