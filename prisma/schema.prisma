generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── ACCOUNT & AUTH ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  role          UserRole  @default(USER)
  activeWebsiteId String?
  lastSeenAt    DateTime?
  isBanned      Boolean   @default(false)
  isMuted       Boolean   @default(false)
  bannedIp      String?
  banReason     String?
  bannedAt      DateTime?
  mutedUntil    DateTime?
  lastIp        String?

  memberships        TeamMember[]
  ownedWebsites      Website[]  @relation("WebsiteOwner")
  assignedTo         ConversationAssignment[]
  assignedConversations Conversation[] @relation("ConversationAssignee")
  notes              Note[]
  sentMessages       Message[]  @relation("MessageSender")
  notifications      Notification[]
  ticketsAssigned    Ticket[]   @relation("TicketAssignee")
  knowledgeArticles  KnowledgeArticle[]
  ticketMessages     TicketMessage[]

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── MULTI-TENANCY ─────────────────────────────────────────────

model Website {
  id        String   @id @default(cuid())
  name      String
  domain    String
  websiteId String   @unique
  plan      Plan     @default(FREE)

  // Widget Customization
  primaryColor   String         @default("#1972F5")
  position      WidgetPosition @default(BOTTOM_RIGHT)

  // Privacy / GDPR
  showConsentBanner  Boolean  @default(true)
  consentBannerText  String?  @default("Bu site, size daha iyi hizmet verebilmek için çerezler ve kişisel verilerinizi işlemektedir. Devam ederek bunu kabul etmiş olursunuz.")
  cookieConsentEnabled Boolean @default(true)
  cookieConsentText  String?  @default("Bu site, deneyiminizi iyileştirmek için çerezler kullanmaktadır.")
  privacyPolicyUrl   String?
  avatarUrl     String?
  welcomeMessage String        @default("Merhaba! Size nasıl yardımcı olabiliriz?")
  offlineMessage String        @default("Şu an çevrimdışısınız. Bir mesaj bırakın, size dönelim.")
  showPreChatForm Boolean      @default(false)
  requireName     Boolean      @default(true)
  requireEmail    Boolean      @default(true)

  // Relations
  ownerId         String
  owner           User           @relation("WebsiteOwner", fields: [ownerId], references: [id])
  members         TeamMember[]
  teamInvites     TeamInvite[]
  conversations   Conversation[]
  visitors        Visitor[]
  cannedResponses CannedResponse[]
  chatbots        Chatbot[]
  webhooks        Webhook[]
  tags            Tag[]
  visitorSessions VisitorSession[]
  aiConfig        AIConfig?
  invoices        Invoice[]
  analytics       AnalyticsSnapshot[]
  notifications   Notification[]
  knowledgeCategories KnowledgeCategory[]
  knowledgeArticles   KnowledgeArticle[]
  tickets             Ticket[]
  statusPage          StatusPage?
  campaigns           Campaign[]
  channelIntegrations ChannelIntegration[]
  workflows           Workflow[]
  addonPurchases      AddonPurchase[]
  conversationRatings ConversationRating[]
  proactiveMessages   ProactiveMessage[]
  gdprConsents        GDPRConsent[]
  dataRetentionPolicy DataRetentionPolicy?

  // PayTR
  paytrMerchantOid      String?            @unique
  paytrUserToken        String?            // utoken — stored card reference
  paytrCardToken        String?            // ctoken — stored card identifier
  subscriptionStatus    SubscriptionStatus @default(NONE)
  currentPeriodEnd      DateTime?
  failedPayments        Int                @default(0)

  // Trial
  trialStartsAt         DateTime?
  trialEndsAt           DateTime?
  trialUsed             Boolean            @default(false)
  trialBonusWidgetGranted Boolean          @default(false)
  trialBonusChatGranted   Boolean          @default(false)

  // Marketing attribution (kayıt anı)
  signupUtmSource    String?
  signupUtmMedium    String?
  signupUtmCampaign  String?
  signupUtmContent   String?
  signupUtmTerm      String?
  signupReferrer     String?
  referralCode       String?
  signupLandingPage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("websites")
}

model TeamMember {
  id        String   @id @default(cuid())
  role      TeamRole @default(MEMBER)
  userId    String
  websiteId String
  invitedBy  String?
  invitedAt  DateTime?
  acceptedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([userId, websiteId])
  @@map("team_members")
}

model TeamInvite {
  id         String    @id @default(cuid())
  email      String
  role       TeamRole  @default(MEMBER)
  token      String    @unique @default(cuid())
  websiteId  String
  invitedBy  String
  invitedAt  DateTime  @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([email, websiteId])
  @@map("team_invites")
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum WidgetPosition {
  BOTTOM_RIGHT
  BOTTOM_LEFT
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  NEW_CONVERSATION
  NEW_MESSAGE
  CONVERSATION_ASSIGNED
  CONVERSATION_RESOLVED
  TEAM_MEMBER_JOINED
  TEAM_MEMBER_REMOVED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  PAYMENT_FAILED
  PAYMENT_SUCCESS
  LIMIT_WARNING
  TRIAL_EXPIRING
}

enum AnalyticsType {
  DAILY
  WEEKLY
  MONTHLY
}

// ─── VISITORS & SESSIONS ──────────────────────────────────────

model Visitor {
  id          String   @id @default(cuid())
  websiteId   String
  fingerprint String
  email       String?
  name        String?
  phone       String?
  avatarUrl   String?
  notes       String?
  customData  String?

  // CRM enrichment
  country  String?
  city     String?
  timezone String?
  browser  String?
  os       String?
  device   String?

  // Relations
  website      Website         @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  sessions     VisitorSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([websiteId, fingerprint])
  @@map("visitors")
}

model VisitorSession {
  id          String   @id @default(cuid())
  visitorId   String
  websiteId   String

  sessionId   String   @unique
  landingPage String?
  currentPage String?
  currentTitle String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  ipAddress   String?
  userAgent   String?
  country     String?
  city        String?
  region      String?
  latitude    Float?
  longitude   Float?
  isp         String?
  timezone    String?
  browser     String?
  os          String?
  device      String?
  deviceType  String?     // mobile, desktop, tablet

  pages       PageView[]

  visitor     Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  startedAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  endedAt      DateTime?

  @@index([websiteId, endedAt])
  @@index([websiteId, lastActiveAt])
  @@map("visitor_sessions")
}

model PageView {
  id        String   @id @default(cuid())
  sessionId String
  url       String
  title     String?
  duration  Int?

  session   VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  viewedAt  DateTime @default(now())

  @@map("page_views")
}

// ─── CONVERSATIONS & MESSAGES ─────────────────────────────────

model Conversation {
  id          String   @id @default(cuid())
  websiteId   String
  visitorId   String

  status      ConversationStatus @default(OPEN)
  source      ConversationSource  @default(WIDGET)
  subject     String?

  // Assignment
  assignedToId String?
  assignedTo   User?  @relation("ConversationAssignee", fields: [assignedToId], references: [id])
  assignments  ConversationAssignment[]

  // Relations
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  visitor     Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  messages    Message[]
  tags        ConversationTag[]
  notes       Note[]
  rating      ConversationRating?

  // Metadata
  lastMessageAt     DateTime @default(now())
  lastMessagePreview String?
  unreadCount       Int      @default(0)

  // Chatbot flow state
  chatbotId         String?
  chatbot           Chatbot?  @relation(fields: [chatbotId], references: [id])
  chatbotStepIndex  Int       @default(0)
  chatbotCompleted  Boolean   @default(false)
  chatbotHandedToAi Boolean   @default(false)
  visitorLang       String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([websiteId, status])
  @@index([websiteId, lastMessageAt])
  @@index([websiteId, createdAt])
  @@map("conversations")
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum ConversationSource {
  WIDGET
  WHATSAPP
  TELEGRAM
  INSTAGRAM
  MESSENGER
  EMAIL
  SMS
  SLACK
  API
  IMPORT
}

model ConversationAssignment {
  id             String   @id @default(cuid())
  conversationId String
  userId         String

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignedBy     String?
  assignedAt     DateTime @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_assignments")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  content        String
  type           MessageType @default(TEXT)
  senderType     SenderType
  sentiment      String?    // POSITIVE | NEUTRAL | NEGATIVE

  // For agent messages
  senderId       String?
  sender         User?    @relation("MessageSender", fields: [senderId], references: [id])

  // Status
  status         MessageStatus @default(SENT)
  readAt         DateTime?
  deliveredAt    DateTime?

  // Attachments
  attachments    Attachment[]

  // Metadata
  metadata       String?
  editedAt       DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
  BOT
}

enum SenderType {
  VISITOR
  AGENT
  BOT
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model Attachment {
  id           String   @id @default(cuid())
  messageId    String
  url          String
  fileName     String
  fileSize     Int?
  mimeType     String?
  thumbnailUrl String?

  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  ticketMessage TicketMessage? @relation(fields: [ticketMessageId], references: [id])
  ticketMessageId String?

  createdAt    DateTime @default(now())

  @@map("attachments")
}

// ─── TAGS & NOTES ─────────────────────────────────────────────

model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#6B7280")
  websiteId   String

  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  conversations ConversationTag[]
  ticketTags  TicketTag[]

  @@unique([websiteId, name])
  @@map("tags")
}

model ConversationTag {
  conversationId String
  tagId          String

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([conversationId, tagId])
  @@map("conversation_tags")
}

model Note {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  content        String

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("notes")
}

// ─── CANNED RESPONSES ──────────────────────────────────────────

model CannedResponse {
  id          String   @id @default(cuid())
  websiteId   String
  title       String
  content     String
  shortcut    String?
  category    String?

  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([websiteId, shortcut])
  @@map("canned_responses")
}

// ─── CHATBOT / AUTO-RESPONDER ─────────────────────────────────

model Chatbot {
  id          String   @id @default(cuid())
  websiteId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  trigger       ChatbotTrigger @default(ALL_CONVERSATIONS)
  triggerValue  String?        // KEYWORD: comma-separated keywords

  steps       ChatbotStep[]
  conversations Conversation[]

  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("chatbots")
}

enum ChatbotTrigger {
  ALL_CONVERSATIONS
  OFFLINE_ONLY
  KEYWORD
  FIRST_VISIT
}

model ChatbotStep {
  id          String   @id @default(cuid())
  chatbotId   String
  order       Int

  // Step config
  type        ChatbotStepType
  message     String?
  options     String?
  nextStepId  String?

  chatbot     Chatbot   @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@map("chatbot_steps")
}

enum ChatbotStepType {
  MESSAGE
  CHOICE
  COLLECT_EMAIL
  COLLECT_NAME
  ASSIGN_AGENT
  END
}

// ─── WEBHOOKS ──────────────────────────────────────────────────

model Webhook {
  id          String   @id @default(cuid())
  websiteId   String
  url         String
  secret      String
  isActive    Boolean  @default(true)

  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  events      WebhookEvent[]

  lastTriggeredAt DateTime?
  failureCount    Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("webhooks")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  webhookId String
  event     String

  webhook   Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_events")
}

// ─── AUDIT LOG ────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  websiteId   String
  userId      String?
  action      String
  entity      String
  entityId    String?
  details     String?

  createdAt   DateTime @default(now())

  @@index([websiteId, action])
  @@map("audit_logs")
}

// ─── AI CONFIG ──────────────────────────────────────────────────

model AIConfig {
  id            String   @id @default(cuid())
  websiteId     String   @unique
  isActive      Boolean  @default(false)
  provider      AIProvider @default(OPENAI)
  model         String   @default("gpt-4o-mini")
  apiKey        String   // Stored encrypted in production
  temperature   Float    @default(0.7)
  systemPrompt  String?
  autoSuggest   Boolean  @default(true)
  autoReply     Boolean  @default(false)

  website       Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("ai_configs")
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  GEMINI
  GROQ
  OPENROUTER
  OLLAMA
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String
  websiteId  String
  type       NotificationType
  title      String
  message    String
  data       String?          // JSON string for additional context
  readAt     DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── INVOICES ───────────────────────────────────────────────────

model Invoice {
  id              String       @id @default(cuid())
  websiteId      String
  plan            Plan
  amount          Int          // In kuruş (cents)
  currency        String       @default("TRY")
  status          InvoiceStatus @default(PENDING)
  periodStart     DateTime
  periodEnd       DateTime
  paytrMerchantOid String?
  pdfUrl          String?

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([websiteId, createdAt])
  @@map("invoices")
}

// ─── ANALYTICS SNAPSHOTS ────────────────────────────────────────

model AnalyticsSnapshot {
  id                    String        @id @default(cuid())
  websiteId            String
  date                  DateTime
  type                  AnalyticsType

  conversationsCreated  Int           @default(0)
  conversationsResolved Int           @default(0)
  uniqueVisitors        Int           @default(0)
  messagesSent          Int           @default(0)
  avgFirstResponseMs    Int           @default(0)
  avgResolutionMs       Int           @default(0)

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([websiteId, date, type])
  @@map("analytics_snapshots")
}

// ─── KNOWLEDGE BASE ──────────────────────────────────────────────

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model KnowledgeCategory {
  id          String   @id @default(cuid())
  websiteId   String
  name        String
  slug        String
  description String?
  icon        String?
  order       Int      @default(0)

  website     Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  articles    KnowledgeArticle[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([websiteId, slug])
  @@map("knowledge_categories")
}

model KnowledgeArticle {
  id          String        @id @default(cuid())
  websiteId   String
  categoryId  String?
  title       String
  slug        String
  content     String
  excerpt     String?
  status      ArticleStatus @default(DRAFT)
  authorId    String?
  author      User?         @relation(fields: [authorId], references: [id])
  viewCount   Int           @default(0)
  helpful     Int           @default(0)
  notHelpful  Int           @default(0)
  tags        String?
  isFeatured  Boolean       @default(false)
  order       Int           @default(0)
  publishedAt DateTime?

  website  Website           @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  category KnowledgeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([websiteId, slug])
  @@index([websiteId, status])
  @@map("knowledge_articles")
}

// ─── TICKETING SYSTEM ────────────────────────────────────────────

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  NEW
  OPEN
  PENDING_CUSTOMER
  PENDING_AGENT
  ON_HOLD
  RESOLVED
  CLOSED
}

enum TicketChannel {
  EMAIL
  WIDGET
  API
  WHATSAPP
  MESSENGER
  INSTAGRAM
  IMPORT
}

model Ticket {
  id          String        @id @default(cuid())
  websiteId   String
  requesterId String?
  requesterEmail String
  requesterName  String?
  subject     String
  description String?
  status      TicketStatus  @default(NEW)
  priority    TicketPriority @default(MEDIUM)
  channel     TicketChannel @default(EMAIL)
  assignedToId String?
  ccAddresses String?

  website    Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("TicketAssignee", fields: [assignedToId], references: [id])
  messages   TicketMessage[]
  tags       TicketTag[]

  closedAt   DateTime?
  firstResponseAt DateTime?
  resolvedAt     DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([websiteId, status])
  @@index([websiteId, priority])
  @@index([websiteId, createdAt])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  content   String
  senderType SenderType
  senderId  String?
  sender    User?     @relation(fields: [senderId], references: [id])
  isInternal Boolean @default(false) // Internal notes

  attachments Attachment[]

  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("ticket_messages")
}

model TicketTag {
  id       String @id @default(cuid())
  ticketId String
  tagId    String

  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([ticketId, tagId])
  @@map("ticket_tags")
}

// ─── STATUS PAGE ────────────────────────────────────────────────

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum ComponentStatus {
  OPERATIONAL
  DEGRADED_PERFORMANCE
  PARTIAL_OUTAGE
  MAJOR_OUTAGE
  UNDER_MAINTENANCE
}

model StatusPage {
  id            String   @id @default(cuid())
  websiteId     String   @unique
  title         String   @default("Service Status")
  description   String?
  subdomain     String   @unique
  customDomain  String?
  logoUrl       String?
  faviconUrl    String?
  isActive      Boolean  @default(true)
  isPublic      Boolean  @default(true)
  primaryColor  String   @default("#1972F5")
  twitterHandle String?
  showHistory   Boolean  @default(true)

  website      Website                @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  components   StatusPageComponent[]
  incidents    Incident[]
  subscribers  StatusPageSubscriber[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("status_pages")
}

model StatusPageSubscriber {
  id           String   @id @default(cuid())
  statusPageId String
  email        String
  isActive     Boolean  @default(true)

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([statusPageId, email])
  @@map("status_page_subscribers")
}

model StatusPageComponent {
  id          String          @id @default(cuid())
  statusPageId String
  name        String
  description String?
  status      ComponentStatus @default(OPERATIONAL)
  order       Int             @default(0)
  groupName   String?

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)

  @@map("status_page_components")
}

model Incident {
  id           String          @id @default(cuid())
  statusPageId String
  title        String
  status       IncidentStatus @default(INVESTIGATING)
  severity     TicketPriority @default(MEDIUM)
  message      String
  components   String?         // JSON array of component IDs
  startedAt    DateTime        @default(now())
  resolvedAt   DateTime?

  statusPage   StatusPage        @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  updates      IncidentUpdate[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("incidents")
}

model IncidentUpdate {
  id         String         @id @default(cuid())
  incidentId String
  status     IncidentStatus
  message    String
  createdAt  DateTime       @default(now())

  incident   Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("incident_updates")
}

// ─── CAMPAIGNS ──────────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignType {
  EMAIL
  IN_APP
  BROADCAST
}

enum CampaignTarget {
  ALL_VISITORS
  ACTIVE_CONVERSATIONS
  SEGMENTED
}

model Campaign {
  id          String         @id @default(cuid())
  websiteId   String
  name        String
  description String?
  type        CampaignType   @default(EMAIL)
  status      CampaignStatus @default(DRAFT)
  target      CampaignTarget @default(ALL_VISITORS)
  segmentFilter String?       // JSON filter criteria
  subject     String?
  content     String?         // HTML content for email / message content
  scheduledAt DateTime?
  sentAt      DateTime?
  sentCount   Int            @default(0)
  openCount   Int            @default(0)
  clickCount  Int            @default(0)
  replyCount  Int            @default(0)

  website    Website         @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([websiteId, status])
  @@map("campaigns")
}

// ─── MULTI-CHANNEL ──────────────────────────────────────────────

enum ChannelType {
  WHATSAPP
  EMAIL
  MESSENGER
  INSTAGRAM
  TELEGRAM
  SLACK
  SMS
}

model ChannelIntegration {
  id        String      @id @default(cuid())
  websiteId String
  type      ChannelType
  name      String
  isActive  Boolean     @default(false)
  config    String?     // JSON config (API keys, webhook URLs, etc)
  lastSyncAt DateTime?

  website   Website     @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([websiteId, type])
  @@map("channel_integrations")
}

// ─── WORKFLOW / AUTOMATION BUILDER ─────────────────────────────

enum WorkflowTriggerType {
  CONVERSATION_CREATED
  CONVERSATION_RESOLVED
  CONVERSATION_CLOSED
  MESSAGE_RECEIVED
  VISITOR_CREATED
  VISITOR_SEEN_PAGE
  TICKET_CREATED
  TICKET_UPDATED
  SCHEDULED
  WEBHOOK_RECEIVED
}

enum WorkflowActionType {
  SEND_MESSAGE
  SEND_EMAIL
  ASSIGN_AGENT
  CHANGE_STATUS
  SET_PRIORITY
  ADD_TAG
  REMOVE_TAG
  FORWARD_TO_WEBHOOK
  ADD_NOTE
  TRIGGER_CHATBOT
  SEND_NOTIFICATION
  DELAY
  CONDITIONAL_BRANCH
}

model Workflow {
  id          String   @id @default(cuid())
  websiteId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  triggerType WorkflowTriggerType
  triggerConfig String? // JSON config for trigger conditions
  order       Int      @default(0)

  website    Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  steps      WorkflowStep[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([websiteId, isActive])
  @@map("workflows")
}

model WorkflowStep {
  id         String             @id @default(cuid())
  workflowId String
  order      Int
  actionType WorkflowActionType
  config     String?            // JSON config for the action
  delayMs    Int?               // Delay before executing this step

  workflow   Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_steps")
}

// ─── CSAT RATING ────────────────────────────────────────────────

model ConversationRating {
  id             String   @id @default(cuid())
  conversationId String   @unique
  websiteId      String
  rating         Int      // 1-5
  comment        String?
  ratedAt        DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  website        Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("conversation_ratings")
}

// ─── ADD-ON / PLUGIN MARKETPLACE ───────────────────────────────

enum AddonCategory {
  ANALYTICS
  AUTOMATION
  AI
  CRM
  MARKETING
  SUPPORT
  SECURITY
  SOCIAL
  ECOMMERCE
  CUSTOM
}

enum PurchaseType {
  ONCE
  MONTHLY
  YEARLY
}

model Addon {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String
  longDescription String?
  category    AddonCategory @default(CUSTOM)
  icon        String?
  imageUrl    String?
  price       Int           // In kuruş (cents), 0 = free
  purchaseType PurchaseType @default(MONTHLY)
  isActive    Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  version     String        @default("1.0.0")
  developer   String        @default("Gu Live Chat")
  docsUrl     String?
  configSchema String?      // JSON schema for addon configuration
  permissions String?       // JSON array of required permissions
  setupGuide  String?       // HTML/markdown setup guide

  purchases   AddonPurchase[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("addons")
}

model AddonPurchase {
  id          String   @id @default(cuid())
  websiteId   String
  addonId     String
  isActive    Boolean  @default(true)
  config      String?  // JSON configuration
  autoRenew   Boolean  @default(true)
  expiresAt   DateTime?
  cancelledAt DateTime?

  website    Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  addon      Addon    @relation(fields: [addonId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([websiteId, addonId])
  @@map("addon_purchases")
}

model ProactiveMessage {
  id          String   @id @default(cuid())
  websiteId   String
  title       String
  message     String
  triggerType String   // 'TIME_ON_PAGE' | 'SCROLL_DEPTH' | 'EXIT_INTENT' | 'PAGE_VISIT' | 'CUSTOM'
  triggerValue String? // seconds, percentage, URL, etc
  targetPages String?  // JSON array of URLs or '*'
  isActive    Boolean  @default(true)
  delay       Int      @default(0) // seconds to wait before showing
  showOnce    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  @@map("proactive_messages")
}

// ─── GDPR / KVKK COMPLIANCE ──────────────────────────────────────────

model GDPRConsent {
  id          String   @id @default(cuid())
  websiteId   String
  visitorId   String?
  consentType String   // 'GDPR' | 'KVKK' | 'COOKIE' | 'DATA_PROCESSING'
  granted     Boolean  @default(false)
  ipAddress   String?
  userAgent   String?
  grantedAt   DateTime @default(now())
  expiresAt   DateTime?
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  @@map("gdpr_consents")
}

model DataRetentionPolicy {
  id              String   @id @default(cuid())
  websiteId       String   @unique
  visitorDataDays Int      @default(365)
  sessionDataDays Int      @default(90)
  chatHistoryDays Int      @default(730)
  autoDelete      Boolean  @default(false)
  lastCleanupAt   DateTime?
  website         Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("data_retention_policies")
}

// ─── IP BAN LIST ────────────────────────────────────────────────

model IpBan {
  id        String    @id @default(cuid())
  ipAddress String    @unique
  reason    String?
  bannedBy  String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@map("ip_bans")
}

// ─── PLATFORM CONFIG (admin) ────────────────────────────────────

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}